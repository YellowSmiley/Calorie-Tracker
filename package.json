{
  "name": "calorie-tracker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n next,tsc,eslint -c cyan,yellow,magenta \"npm run dev:next\" \"npm run dev:types\" \"npm run dev:lint\"",
    "dev:next": "next dev",
    "dev:types": "tsc --noEmit --watch --preserveWatchOutput",
    "dev:lint": "eslint . --cache --cache-location .eslintcache",
    "build": "prisma generate && prisma migrate deploy && next build",
    "generate": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "test": "jest --watch",
    "test:ci": "jest --ci",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "migrate": "prisma migrate dev",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npx cap sync",
    "cap:sync:android": "npx cap sync android",
    "cap:sync:dev:android": "powershell -NoProfile -Command \"$env:CAP_SERVER_URL='http://10.0.2.2:3000'; npx cap sync android\"",
    "cap:sync:prod:android": "node scripts/cap-sync-prod.mjs android",
    "cap:sync:prod:ios": "node scripts/cap-sync-prod.mjs ios",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "cap:run:android": "npx cap run android",
    "cap:run:ios": "npx cap run ios",
    "mobile:install": "npm --prefix mobile install",
    "mobile:start": "npm --prefix mobile start",
    "mobile:android": "npm --prefix mobile run android",
    "mobile:ios": "npm --prefix mobile run ios"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.8.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^2.0.0",
    "@zxing/library": "^0.21.3",
    "badwords-list": "^2.0.1-4",
    "bcryptjs": "^3.0.3",
    "ioredis": "^5.10.1",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^7.0.13",
    "pg": "^8.18.0",
    "rate-limiter-flexible": "^9.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.0",
    "stripe": "^22.0.2",
    "tesseract.js": "^7.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}