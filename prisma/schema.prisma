generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  accounts      Account[]
  sessions      Session[]
  mealEntries   MealEntry[]
  mealFavorites MealFavorite[]
  weightEntries WeightEntry[]
  createdFoods  Food[]
  approvedFoods Food[]     @relation("FoodApprovals")
  foodReportsMade FoodReport[] @relation("FoodReportsMade")
  resolvedFoodReports FoodReport[] @relation("FoodReportsResolved")
  provider      String?    @default("credentials") // 'google', 'credentials', etc.
  isActive      Boolean    @default(true)
  blackMarks    Int        @default(0)
  bannedAt      DateTime?
  lastKnownIp   String?    @db.VarChar(64)
  isPremium     Boolean    @default(false)
  premiumExpiresAt DateTime?
  stripeCustomerId String? @unique @db.VarChar(255)
  stripeSubscriptionId String? @unique @db.VarChar(255)
  stripePriceId String?   @db.VarChar(255)
  subscriptionStatus String? @db.VarChar(64)
  
  // User role
  isAdmin       Boolean    @default(false)
  
  // Nutritional goals
  calorieGoal   Float?     @default(3000)
  proteinGoal   Float?     @default(150)
  carbGoal      Float?     @default(410)
  fatGoal       Float?     @default(83)
  saturatesGoal Float    @default(20)
  sugarsGoal    Float    @default(90)
  fibreGoal     Float    @default(30)
  saltGoal      Float    @default(6)
  
  // Measurement preferences
  calorieUnit   String?    @default("kcal")
  // macroUnit removed; use weightUnit instead
  weightUnit    String?    @default("g")
  bodyWeightUnit String?   @default("kg")
  volumeUnit    String?    @default("ml")
}

model BlacklistEntry {
  id        String   @id @default(cuid())
  entryType String   @db.VarChar(16)
  value     String   @db.VarChar(255)
  reason    String?  @db.VarChar(255)
  createdAt DateTime @default(now())

  @@unique([entryType, value])
  @@index([value])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Food {
  id          String   @id @default(cuid())
  name        String
  measurementAmount Float
  measurementType String
  calories    Float
  protein     Float
  carbs       Float
  fat         Float
  saturates  Float    @default(0)
  sugars     Float    @default(0)
  fibre      Float    @default(0)
  salt       Float    @default(0)
  defaultServingAmount      Float?
  defaultServingDescription String?   @db.VarChar(50)
  createdBy   String?
  isApproved  Boolean  @default(false)
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator  User? @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  approver User? @relation("FoodApprovals", fields: [approvedBy], references: [id], onDelete: SetNull)
  entries  MealEntry[]
  mealFavoriteItems MealFavoriteItem[]
  reports FoodReport[]
}

model FoodReport {
  id          String   @id @default(cuid())
  foodId      String
  reportedBy  String
  reason      String?  @db.VarChar(250)
  isResolved  Boolean  @default(false)
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  food      Food  @relation(fields: [foodId], references: [id], onDelete: Cascade)
  reporter  User  @relation("FoodReportsMade", fields: [reportedBy], references: [id], onDelete: Cascade)
  resolver  User? @relation("FoodReportsResolved", fields: [resolvedBy], references: [id], onDelete: SetNull)

  @@index([foodId, isResolved])
  @@index([reportedBy, isResolved])
}

model MealFavorite {
  id        String             @id @default(cuid())
  userId    String
  name      String
  mealType  MealType
  usageCount Int               @default(0)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  items MealFavoriteItem[]

  @@index([userId, mealType])
  @@unique([userId, name, mealType])
}

model MealFavoriteItem {
  id         String       @id @default(cuid())
  favoriteId String
  foodId     String
  serving    Float
  sortOrder  Int          @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  favorite MealFavorite @relation(fields: [favoriteId], references: [id], onDelete: Cascade)
  food     Food         @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@index([favoriteId])
  @@index([foodId])
}

model MealEntry {
  id        String   @id @default(cuid())
  userId    String
  foodId    String
  mealType  MealType
  date      DateTime
  serving   Float
  calories  Float
  protein   Float
  carbs     Float
  fat       Float
  saturates  Float    @default(0)
  sugars     Float    @default(0)
  fibre      Float    @default(0)
  salt       Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  food Food @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model WeightEntry {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  weight    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model AuditLog {
  id         String   @id @default(cuid())
  occurredAt DateTime @default(now())
  actorId    String   @db.VarChar(128)
  actorRole  String   @db.VarChar(32)
  targetType String   @db.VarChar(64)
  targetId   String   @db.VarChar(128)
  action     String   @db.VarChar(64)
  reason     String?  @db.VarChar(500)
  metadata   Json?
  requestId  String?  @db.VarChar(256)

  @@index([occurredAt])
  @@index([actorId, occurredAt])
  @@index([targetType, targetId, occurredAt])
  @@index([action, occurredAt])
}
