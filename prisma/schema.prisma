generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
  SNACK
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  accounts      Account[]
  sessions      Session[]
  mealEntries   MealEntry[]
  createdFoods  Food[]
  
  // User role
  isAdmin       Boolean    @default(false)
  
  // Nutritional goals
  calorieGoal   Float?     @default(3000)
  proteinGoal   Float?     @default(150)
  carbGoal      Float?     @default(410)
  fatGoal       Float?     @default(83)
  
  // Measurement preferences
  calorieUnit   String?    @default("kcal")
  macroUnit     String?    @default("g")
  weightUnit    String?    @default("g")
  volumeUnit    String?    @default("ml")
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Food {
  id          String   @id @default(cuid())
  name        String
  measurement String
  calories    Float
  protein     Float
  carbs       Float
  fat         Float
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator  User? @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  entries  MealEntry[]
}

model MealEntry {
  id        String   @id @default(cuid())
  userId    String
  foodId    String
  mealType  MealType
  date      DateTime
  serving   Float
  calories  Float
  protein   Float
  carbs     Float
  fat       Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  food Food @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}
